@model IEnumerable<prjRentalManagement.Models.owner>

@{
    ViewBag.Title = Session["manager"] != null ? "Owners (admin)" : "Your Information";
}

@if (Session["owner"] == null && Session["manager"] == null)
{
    Response.Redirect("~/OwnerAccess/Login");
}
else
{
    <h2>@ViewBag.Title</h2>
}

<table class="table">
    <tr>
        <th>Name</th>
        <th>Email</th>
        <th>Phone</th>
        <th></th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@Html.DisplayFor(modelItem => item.name)</td>
            <td>@Html.DisplayFor(modelItem => item.email)</td>
            <td>@Html.DisplayFor(modelItem => item.phoneNumber)</td>
            <td>
                @Html.ActionLink("Edit", "Edit", new { id = item.ownerId }, new { @class = "btn btn-warning btn-sm" }) |
                @Html.ActionLink("Details", "Details", new { id = item.ownerId }, new { @class = "btn btn-info btn-sm" }) |
                @Html.ActionLink("Delete", "Delete", new { id = item.ownerId }, new { @class = "btn btn-danger btn-sm" })
            </td>
        </tr>
    }
</table>
