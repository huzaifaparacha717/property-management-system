@model prjRentalManagement.Models.owner
@{
    ViewBag.Title = "Owner sign up";
}

<div class="prm-auth-stack">
<div class="prm-card prm-card--padded">
    <h2>Owner portal — sign up</h2>
    <p>Create an owner account to add buildings and list apartments.</p>

    @using (Html.BeginForm("Register", "OwnerAccess", FormMethod.Post))
    {
        @Html.AntiForgeryToken()
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })
        <div class="form-group mb-2">
            @Html.LabelFor(m => m.name)
            @Html.EditorFor(m => m.name, new { htmlAttributes = new { @class = "form-control" } })
            @Html.ValidationMessageFor(m => m.name, "", new { @class = "text-danger" })
        </div>
        <div class="form-group mb-2">
            @Html.LabelFor(m => m.email)
            @Html.EditorFor(m => m.email, new { htmlAttributes = new { @class = "form-control" } })
            @Html.ValidationMessageFor(m => m.email, "", new { @class = "text-danger" })
        </div>
        <div class="form-group mb-2">
            @Html.LabelFor(m => m.password)
            @Html.EditorFor(m => m.password, new { htmlAttributes = new { @class = "form-control", maxlength = "64", type = "password" } })
            @Html.ValidationMessageFor(m => m.password, "", new { @class = "text-danger" })
        </div>
        <div class="form-group mb-3">
            @Html.LabelFor(m => m.phoneNumber)
            @Html.EditorFor(m => m.phoneNumber, new { htmlAttributes = new { @class = "form-control" } })
            @Html.ValidationMessageFor(m => m.phoneNumber, "", new { @class = "text-danger" })
        </div>
        <input type="submit" value="Create account" class="btn btn-primary" />
    }

    <p class="mt-3 mb-0">
        Already have an account? @Html.ActionLink("Sign in", "Login", "OwnerAccess")
    </p>
</div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
