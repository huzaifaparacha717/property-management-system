@model IEnumerable<prjRentalManagement.Models.booking>
@using prjRentalManagement.Helpers
@{
    ViewBag.Title = "Owner dashboard — booking requests";
}

<h2>Booking requests</h2>
<p class="text-muted">Pending tenant requests for your listings. Confirm to assign the tenant and mark the unit <strong>Booked</strong>, or cancel the request.</p>

@if (TempData["Message"] != null)
{
    <div class="alert alert-success">@TempData["Message"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

@if (Model == null || !Model.Any())
{
    <div class="alert alert-info">No pending booking requests.</div>
}
else
{
    <div class="table-responsive prm-table-wrap">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>Requested</th>
                    <th>Tenant</th>
                    <th>Apartment</th>
                    <th>Location</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var b in Model)
                {
                    var apt = b.apartment;
                    var bld = apt?.building;
                    <tr>
                        <td>@b.requestDate.ToLocalTime().ToString("g")</td>
                        <td>@(b.tenant != null ? b.tenant.name : "—")<br /><span class="small text-muted">@(b.tenant?.email)</span></td>
                        <td>#@(apt?.apartmentNo) <span class="text-muted small">(ID @b.apartmentId)</span></td>
                        <td>@(bld != null ? bld.address + ", " + bld.city : "—")</td>
                        <td><span class="badge @BookingStatusDisplay.BadgeClass(b.status)">@b.status</span></td>
                        <td class="text-nowrap">
                            @using (Html.BeginForm("Approve", "OwnerBooking", new { id = b.bookingId }, FormMethod.Post, new { @class = "d-inline" }))
                            {
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-success btn-sm">Approve</button>
                            }
                            @using (Html.BeginForm("Reject", "OwnerBooking", new { id = b.bookingId }, FormMethod.Post, new { @class = "d-inline ms-1" }))
                            {
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-danger btn-sm">Reject</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<p class="mt-3">@Html.ActionLink("Back to my listings", "Index", "Apartment")</p>
